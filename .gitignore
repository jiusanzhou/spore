# OS
.DS_Store
Thumbs.db

# Spore data
*.db
.spore/

# Demo runtime artifacts — agents mutate these at runtime.
# Already-tracked baseline files (agent.yaml, spore.toml, skills/<baseline>)
# are unaffected; this just stops new runtime-generated skills/experience/
# evolution/memory data from getting committed.
examples/*/*/JOURNAL.md
examples/*/*/evolution/
examples/*/*/experience/
examples/*/*/memory/
examples/*/*/skills/
# Nested agent dirs created by mistake during demo runs (e.g. scout/scout/)
examples/*/*/identity.json
examples/*/*/identity.key
examples/consciousness-demo/scout/scout/
examples/consciousness-demo/boss/boss/
examples/consciousness-demo/forge/forge/

# Secrets
*.key
*.pem
.env

# LLM-generated files (from builtin runtime tool calls)
example*.go
example*.py
concurrency_example*
channel_example*

